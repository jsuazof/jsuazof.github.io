---
const personalImageAlt = "Jorge Suazo Fuenzalida"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16"
      src="/jsf01.webp"
      alt={personalImageAlt}
    />
    <a
      href="https://linkedin.com/in/jorgesuazof"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Disponible para trabajar</Badge>
    </a>
  </div>
  <h1
    class="text-3xl font-bold tracking-tight text-gray-800 sm:text-3xl dark:text-white"
  >
    Hola, soy Jorge Suazo Fuenzalida
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >
    +30 años de experiencia en TI. <strong
      >Ingeniero Informatico, SysAdmin y los ultimos 3 años como Desarrollador FullStack</strong
    > Especialista en desarrollo de soluciones en la nube.
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="mailto:jsuazof@gmail.com">
      <MailIcon class="size-4" />
      Contáctame
    </SocialPill>
    <SocialPill href="https://linkedin.com/in/jorgesuazof">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
  </nav>
</div>
